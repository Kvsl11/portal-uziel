rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin'] ||
         request.auth.token.email == "kaio.vsl11@gmail.com");
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }

    // Members collection
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Attendance collection
    match /attendance/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Repertory collection
    match /repertory/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Playlists collection
    match /playlists/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Rehearsals collection
    match /rehearsals/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Justifications collection
    match /justifications/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Polls collection
    match /polls/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Audit logs
    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Settings
    match /settings/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Schedules
    match /schedules/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Chat histories
    match /chat_histories/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Daily images
    match /daily_images/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Liturgy cache
    match /liturgy_cache/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Daily quotes
    match /daily_quotes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
